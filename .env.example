# Local runtime env vars for `dotnet run`
# ASP.NET Core binds these as section__property keys.

# Database
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=ArgenCashDB;Username=postgres;Password=change-me

# JWT (SecretKey must be at least 32 chars)
Jwt__Issuer=ArgenCash.Api
Jwt__Audience=ArgenCash.Frontend
Jwt__SecretKey=
Jwt__ExpirationMinutes=60

# Verification token (SecretKey must be at least 32 chars)
VerificationToken__SecretKey=
VerificationToken__ExpirationMinutes=15
VerificationToken__Issuer=ArgenCash.Api

# SMTP (leave Host empty to disable SMTP validation locally)
Smtp__Host=smtp.gmail.com
Smtp__Port=587
Smtp__Username=
Smtp__Password=
Smtp__FromName=ArgenCash
Smtp__FromEmail=

# Exchange rate provider
ExchangeRateApi__BaseUrl=https://dolarapi.com/
ExchangeRateApi__SourceName=dolarapi.com

# App URLs
AllowedOrigins__0=http://localhost:3000
FrontendUrl=http://localhost:3000
